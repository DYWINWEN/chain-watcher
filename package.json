{
  "name": "chain-watcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Real-time BSC/BTC/ETH large-transfer & repeated-counterparty alert tool",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p . && node scripts/copy-assets.js",
    "migrate": "tsx src/storage/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' 'scripts/**/*.ts'",
    "format": "prettier --write 'src/**/*.{ts,js,json}'"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "bullmq": "^5.21.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.1",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.0",
    "node-telegram-bot-api": "^0.66.0",
    "p-limit": "^6.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
